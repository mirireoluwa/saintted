# Backend API base — must include /api (Django). No trailing slash.
# Production example: https://your-api.up.railway.app/api
VITE_API_URL=http://localhost:8000/api

# Canonical site origin for Open Graph / Twitter cards (no trailing slash). Used in index.html at build time.
VITE_SITE_URL=https://saintted.com
# Optional: comma-separated extra hostnames that should load admin-only routing (preview domains, etc.)
# VITE_ADMIN_HOSTS=admin-staging.vercel.app
# Optional: full origin for the “admin subdomain” callout link (defaults to admin.{VITE_SITE_URL host})
# VITE_ADMIN_SITE_URL=https://admin.saintted.com

# Optional: Sentry browser SDK (error + performance). Leave unset to disable.
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
