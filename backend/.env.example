# Copy to ".env" in this folder (backend/.env) and adjust.
# cp .env.example .env

# --- Production (Render, etc.) — set in the host dashboard, not only in this file ---
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=long-random-string
# DATABASE_URL=postgres://...   # Render PostgreSQL “Internal/External URL”
# DJANGO_ALLOWED_HOSTS=saintted-api.onrender.com,your.custom.api.domain
# CORS_ORIGINS=https://saintted.com,https://www.saintted.com,https://your-app.vercel.app
# CSRF_TRUSTED_ORIGINS=https://saintted.com,https://www.saintted.com,https://your-app.vercel.app
#
# Persistent media storage (recommended in production):
# USE_S3_MEDIA=1
# S3_BUCKET_NAME=your-bucket-name
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=https://<account-or-provider-endpoint>
# S3_CUSTOM_DOMAIN=<public-media-domain-or-cdn-domain>
# S3_MEDIA_LOCATION=media
# Optional for S3-compatible providers:
# S3_ADDRESSING_STYLE=path

# How your name appears on Apple Music / Spotify (cover-art search when art_url is empty)
# COVER_ART_ARTIST=Saintted

# Optional: Spotify API for cover fallback when iTunes has no match
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Optional emergency admin password reset (required in production for reset endpoint):
# RESET_PASSWORD_SECRET=very-long-random-secret

# Optional tuning
# COVER_ART_CACHE_TTL=86400
# COVER_ART_ITUNES_TIMEOUT=8
